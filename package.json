{
  "name": "yearcal",
  "private": true,
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently --names \"back,front\" -c \"blue,green\" \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "cd frontend && node ../node_modules/vite/bin/vite.js build && cd .. && node node_modules/typescript/bin/tsc -p backend/tsconfig.json",
    "start": "node app.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "backend": "file:backend",
    "frontend": "file:frontend",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "vite": "^5.3.5",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.12",
    "@types/uuid": "^10.0.0"
  }
}
